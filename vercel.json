{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "tinacms build --skip-cloud-checks && next build",
  "redirects": [
    {
      "source": "/blog/first-test1",
      "destination": "/blog",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/send-newsletter",
      "schedule": "0 9 * * *"
    }
  ]
}
