# This file is a placeholder for environment variables required to run this project.
# Currently, there are no environment variables needed.

# Example of what future variables might look like:
# NEXT_PUBLIC_API_KEY=your_api_key_here
# DATABASE_URL=your_database_url_here
# SECRET_KEY=your_secret_key_here

# Password for protected pages/routes
PAGE_ACCESS_PASSWORD=password

# ===== Newsletter (Resend) =====
# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Resend Segment(原 Audience) ID — 订阅者名单
RESEND_SEGMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 发件人(需在 Resend 验证过的域名), 格式: "Name <sender@domain>"
NEWSLETTER_FROM=Cool Bao <news@khtain.com>
# 保护 /api/send-newsletter 定时任务的密钥(自己生成一段随机字符串)
CRON_SECRET=change-me-to-a-long-random-string
